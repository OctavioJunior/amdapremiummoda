---
import BaseLayout from '../layouts/BaseLayout.astro';
import produtos from '../data/produtos.json';
import ProductCard from '../components/ProductCard.astro';

const destaques = produtos.items.slice(0, 3);
---

<BaseLayout title="Início" description="AMDA Premium Moda — Elegância e sofisticação em cada peça.">

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="hero-eyebrow">Nova Coleção 2025</p>
        <h1 class="hero-title">
          Elegância<br />
          <em>que transforma</em>
        </h1>
        <p class="hero-desc">
          Peças cuidadosamente selecionadas para a mulher que valoriza o refinamento no dia a dia.
        </p>
        <a href="/produtos" class="hero-cta">
          Ver Coleção Completa
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M4 10h12M12 5l5 5-5 5"/>
          </svg>
        </a>
      </div>

      <div class="hero-visual">
        <div class="hero-card-stack">
          <div class="hc hc-back"></div>
          <div class="hc hc-mid"></div>
          <div class="hc hc-front">
            <div class="hc-inner">
              <div class="hc-badge">Premium</div>
              <p class="hc-label">Estilo &amp; Sofisticação</p>
            </div>
          </div>
        </div>
        <div class="hero-floater">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/>
          </svg>
          <span>Qualidade Premium</span>
        </div>
      </div>
    </div>

    <!-- decorative -->
    <div class="hero-deco hero-deco--1" aria-hidden="true"></div>
    <div class="hero-deco hero-deco--2" aria-hidden="true"></div>
  </section>

  <!-- ── STRIP VALORES ── -->
  <section class="values-strip" aria-label="Nossos valores">
    <div class="values-inner">
      {[
        { icon: '✦', text: 'Peças selecionadas' },
        { icon: '♡', text: 'Feito com cuidado' },
        { icon: '◈', text: 'Qualidade premium' },
        { icon: '✉', text: 'Atendimento via WhatsApp' },
      ].map(v => (
        <div class="value-item">
          <span class="value-icon">{v.icon}</span>
          <span class="value-text">{v.text}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ── DESTAQUES ── -->
  <section class="section">
    <div class="section-inner">
      <header class="section-header">
        <p class="section-eyebrow">Selecionados para você</p>
        <h2 class="section-title">Destaques da Coleção</h2>
      </header>

      <div class="products-grid products-grid--3">
        {destaques.map(p => (
          <ProductCard nome={p.nome} preco={p.preco} imagem={p.imagem} />
        ))}
      </div>

      <div class="section-cta">
        <a href="/produtos" class="btn-outline">
          Ver todos os produtos
        </a>
      </div>
    </div>
  </section>

  <!-- ── BANNER CTA ── -->
  <section class="cta-banner" aria-label="Fale conosco">
    <div class="cta-banner-inner">
      <div class="cta-text">
        <h2 class="cta-title">Dúvidas ou quer ajuda para escolher?</h2>
        <p class="cta-desc">Nossa equipe está pronta para te atender com toda atenção que você merece.</p>
      </div>
      <a
        href="https://wa.me/5551984229690?text=Olá!%20Gostaria%20de%20saber%20mais%20sobre%20a%20coleção%20AMDA%20Premium."
        target="_blank"
        rel="noopener noreferrer"
        class="cta-wbtn"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Falar no WhatsApp
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── HERO ── */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 80px 24px 100px;
    background: linear-gradient(135deg, var(--bg) 0%, #EFE8E5 100%);
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .hero-eyebrow {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rose);
    margin-bottom: 16px;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 300;
    line-height: 1.05;
    color: var(--text);
    margin-bottom: 24px;
  }

  .hero-title em {
    font-style: italic;
    color: var(--rose-dark);
    font-weight: 400;
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 420px;
    margin-bottom: 40px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--rose-dark);
    color: var(--white);
    padding: 16px 36px;
    border-radius: var(--radius-pill);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: background var(--transition), transform var(--transition);
  }

  .hero-cta:hover {
    background: var(--rose);
    transform: translateY(-2px);
  }

  .hero-cta svg {
    width: 18px;
    height: 18px;
    transition: transform var(--transition);
  }

  .hero-cta:hover svg { transform: translateX(4px); }

  /* Visual card stack */
  .hero-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 420px;
  }

  .hero-card-stack { position: relative; width: 260px; height: 340px; }

  .hc {
    position: absolute;
    border-radius: 20px;
    transition: transform var(--transition);
  }

  .hc-back {
    width: 100%; height: 100%;
    background: var(--rose-light);
    transform: rotate(8deg) translateY(10px);
    opacity: 0.5;
  }

  .hc-mid {
    width: 100%; height: 100%;
    background: var(--rose);
    transform: rotate(3deg) translateY(4px);
    opacity: 0.65;
  }

  .hc-front {
    width: 100%; height: 100%;
    background: linear-gradient(145deg, var(--rose-dark), #6E4040);
    display: flex;
    align-items: flex-end;
    padding: 28px;
  }

  .hc-inner { color: var(--white); }

  .hc-badge {
    display: inline-block;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border: 1px solid rgba(255,255,255,0.4);
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: 10px;
    opacity: 0.85;
  }

  .hc-label {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 300;
    font-style: italic;
    line-height: 1.2;
    opacity: 0.9;
  }

  .hero-floater {
    position: absolute;
    bottom: 20px;
    right: -10px;
    background: var(--white);
    border-radius: var(--radius-md);
    padding: 12px 18px;
    display: flex;
    align-items: center;
    gap: 10px;
    box-shadow: var(--shadow-hover);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--rose-dark);
    letter-spacing: 0.05em;
  }

  .hero-floater svg {
    width: 18px; height: 18px;
    color: var(--rose);
    flex-shrink: 0;
  }

  /* Decorative blobs */
  .hero-deco {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .hero-deco--1 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(197, 138, 122, 0.12) 0%, transparent 70%);
    top: -100px; right: -100px;
  }

  .hero-deco--2 {
    width: 300px; height: 300px;
    background: radial-gradient(circle, rgba(140, 90, 82, 0.08) 0%, transparent 70%);
    bottom: -80px; left: 60px;
  }

  /* ── VALUES STRIP ── */
  .values-strip {
    background: var(--rose-dark);
    padding: 20px 24px;
  }

  .values-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px 40px;
  }

  .value-item {
    display: flex;
    align-items: center;
    gap: 10px;
    color: rgba(255,255,255,0.85);
  }

  .value-icon {
    font-size: 0.8rem;
    color: var(--rose-light);
  }

  .value-text {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 400;
  }

  /* ── SECTION ── */
  .section {
    padding: 90px 24px;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .section-eyebrow {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rose);
    margin-bottom: 12px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    color: var(--text);
  }

  .products-grid {
    display: grid;
    gap: 28px;
  }

  .products-grid--3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .section-cta {
    text-align: center;
    margin-top: 52px;
  }

  .btn-outline {
    display: inline-block;
    padding: 14px 40px;
    border: 1.5px solid var(--rose-dark);
    border-radius: var(--radius-pill);
    color: var(--rose-dark);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: background var(--transition), color var(--transition), transform var(--transition);
  }

  .btn-outline:hover {
    background: var(--rose-dark);
    color: var(--white);
    transform: translateY(-2px);
  }

  /* ── CTA BANNER ── */
  .cta-banner {
    background: linear-gradient(135deg, var(--rose-light) 0%, #D9B0A6 100%);
    padding: 72px 24px;
  }

  .cta-banner-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    flex-wrap: wrap;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 400;
    color: var(--rose-dark);
    margin-bottom: 10px;
  }

  .cta-desc {
    font-size: 0.95rem;
    color: var(--rose-dark);
    opacity: 0.8;
    max-width: 440px;
  }

  .cta-wbtn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #25D366;
    color: #fff;
    padding: 16px 32px;
    border-radius: var(--radius-pill);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.35);
    white-space: nowrap;
    transition: background var(--transition), transform var(--transition);
    flex-shrink: 0;
  }

  .cta-wbtn:hover {
    background: #1DA851;
    transform: translateY(-2px);
  }

  .cta-wbtn svg {
    width: 20px; height: 20px;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 48px; }
    .hero-visual { height: 300px; }
    .hero-card-stack { width: 200px; height: 260px; }

    .products-grid--3 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .hero { padding: 60px 20px 80px; }
    .products-grid--3 { grid-template-columns: 1fr; }
    .cta-banner-inner { flex-direction: column; text-align: center; }
    .cta-wbtn { width: 100%; justify-content: center; }
  }
</style>
