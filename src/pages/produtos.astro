---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import produtos from '../data/produtos.json';
---

<BaseLayout title="Produtos" description="Confira a coleção completa AMDA Premium Moda.">

  <!-- PAGE HEADER -->
  <section class="page-hero">
    <div class="page-hero-inner">
      <p class="page-eyebrow">Coleção 2025</p>
      <h1 class="page-title">Nossa Coleção</h1>
      <p class="page-desc">
        Cada peça foi escolhida a dedo para oferecer o melhor em estilo e qualidade.
      </p>
    </div>
    <div class="page-hero-deco" aria-hidden="true"></div>
  </section>

  <!-- PRODUCTS GRID -->
  <section class="products-section">
    <div class="products-inner">

      <div class="products-meta">
        <span class="products-count">{produtos.items.length} peças disponíveis</span>
      </div>

      {produtos.items.length > 0 ? (
        <div class="products-grid">
          {produtos.items.map(p => (
            <ProductCard nome={p.nome} preco={p.preco} imagem={p.imagem} />
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <div class="empty-icon">🛍️</div>
          <h3>Em breve, novidades!</h3>
          <p>Estamos preparando nossa coleção. Volte em breve ou fale conosco pelo WhatsApp.</p>
          <a
            href="https://wa.me/5551984229690?text=Olá!%20Gostaria%20de%20saber%20quando%20a%20coleção%20AMDA%20estará%20disponível."
            target="_blank"
            rel="noopener noreferrer"
            class="empty-cta"
          >
            Falar no WhatsApp
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="bottom-cta">
    <div class="bottom-cta-inner">
      <p class="bottom-cta-text">
        Não encontrou o que procurava? Fale com a gente!
      </p>
      <a
        href="https://wa.me/5551984229690?text=Olá!%20Estou%20procurando%20uma%20peça%20específica%20na%20AMDA%20Premium."
        target="_blank"
        rel="noopener noreferrer"
        class="bottom-cta-btn"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Falar com Atendimento
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── PAGE HERO ── */
  .page-hero {
    position: relative;
    overflow: hidden;
    padding: 72px 24px 80px;
    background: linear-gradient(135deg, var(--bg-warm) 0%, #EAE0DC 100%);
    text-align: center;
  }

  .page-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 600px;
    margin: 0 auto;
  }

  .page-eyebrow {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--rose);
    margin-bottom: 14px;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 300;
    color: var(--text);
    margin-bottom: 18px;
    line-height: 1.1;
  }

  .page-desc {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .page-hero-deco {
    position: absolute;
    top: -100px; right: -100px;
    width: 400px; height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(197, 138, 122, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ── PRODUCTS SECTION ── */
  .products-section {
    padding: 60px 24px 80px;
  }

  .products-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .products-meta {
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .products-count {
    font-size: 0.8rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  /* ── EMPTY STATE ── */
  .empty-state {
    text-align: center;
    padding: 80px 24px;
  }

  .empty-icon {
    font-size: 3rem;
    margin-bottom: 20px;
  }

  .empty-state h3 {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 400;
    margin-bottom: 12px;
  }

  .empty-state p {
    color: var(--text-muted);
    margin-bottom: 32px;
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
  }

  .empty-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #25D366;
    color: #fff;
    padding: 14px 32px;
    border-radius: var(--radius-pill);
    font-size: 0.82rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: background var(--transition);
  }

  .empty-cta:hover { background: #1DA851; }

  /* ── BOTTOM CTA ── */
  .bottom-cta {
    background: var(--bg-warm);
    border-top: 1px solid var(--border);
    padding: 48px 24px;
  }

  .bottom-cta-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }

  .bottom-cta-text {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 400;
    font-style: italic;
    color: var(--rose-dark);
  }

  .bottom-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #25D366;
    color: #fff;
    padding: 14px 28px;
    border-radius: var(--radius-pill);
    font-size: 0.78rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
    box-shadow: 0 4px 16px rgba(37, 211, 102, 0.3);
    transition: background var(--transition), transform var(--transition);
    flex-shrink: 0;
  }

  .bottom-cta-btn:hover {
    background: #1DA851;
    transform: translateY(-2px);
  }

  .bottom-cta-btn svg { width: 18px; height: 18px; }

  /* ── RESPONSIVE ── */
  @media (max-width: 1100px) {
    .products-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .products-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .bottom-cta-inner { flex-direction: column; text-align: center; }
    .bottom-cta-btn { width: 100%; justify-content: center; }
  }

  @media (max-width: 480px) {
    .products-grid { grid-template-columns: 1fr; }
  }
</style>
