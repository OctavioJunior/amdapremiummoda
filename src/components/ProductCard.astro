---
import WhatsButton from './WhatsButton.astro';

export interface Props {
  nome: string;
  preco: number;
  imagem: string;
}

const { nome, preco, imagem } = Astro.props;

const precoFormatado = preco.toLocaleString('pt-BR', {
  style: 'currency',
  currency: 'BRL',
});

// Fallback placeholder se imagem não existir
const imgSrc = imagem || '/placeholder.svg';
---

<article class="product-card">
  <div class="card-image-wrap">
    <img
      src={imgSrc}
      alt={nome}
      class="card-image"
      loading="lazy"
      onerror="this.src='/placeholder.svg'"
    />
    <div class="card-overlay">
      <WhatsButton nomeProduto={nome} variant="ghost" />
    </div>
  </div>

  <div class="card-body">
    <h3 class="card-nome">{nome}</h3>
    <p class="card-preco">{precoFormatado}</p>
    <div class="card-action">
      <WhatsButton nomeProduto={nome} />
    </div>
  </div>
</article>

<style>
  .product-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
    transition: transform var(--transition), box-shadow var(--transition);
    display: flex;
    flex-direction: column;
  }

  .product-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-hover);
  }

  .card-image-wrap {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--bg-warm);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .product-card:hover .card-image {
    transform: scale(1.06);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(44, 30, 27, 0.35);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 20px;
    opacity: 0;
    transition: opacity var(--transition);
  }

  .product-card:hover .card-overlay {
    opacity: 1;
  }

  /* On overlay, override ghost to white */
  .card-overlay :global(.whats-btn--ghost) {
    color: #fff;
    border-color: #fff;
  }

  .card-body {
    padding: 20px 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  .card-nome {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.3;
  }

  .card-preco {
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--rose-dark);
    letter-spacing: 0.03em;
  }

  .card-action {
    margin-top: 14px;
  }

  .card-action :global(.whats-btn) {
    width: 100%;
    justify-content: center;
  }
</style>
